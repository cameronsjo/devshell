#!/bin/bash
# p — project picker
# Usage: p          (pick project, open in named tmux session)
#        p <query>  (fuzzy match project name, skip picker if unique)
set -euo pipefail

PROJECTS_DIR="${HOME}/Projects"

attach_or_switch() {
    local session="$1"
    if [ -n "${TMUX:-}" ]; then
        tmux switch-client -t "$session"
    else
        tmux attach-session -t "$session"
    fi
}

open_project() {
    local dir="$1"
    local name
    name="$(basename "$dir")"

    # If session exists, just attach
    if tmux has-session -t "$name" 2>/dev/null; then
        attach_or_switch "$name"
        return
    fi

    # Create session cd'd into the project
    tmux new-session -d -s "$name" -c "$dir"
    attach_or_switch "$name"
}

# Git status indicator for a directory
git_indicator() {
    local dir="$1"
    if [ ! -d "${dir}/.git" ]; then
        echo ""
        return
    fi

    local status
    status="$(git -C "$dir" status --porcelain 2>/dev/null)"
    if [ -z "$status" ]; then
        # Check for unpushed commits
        local ahead
        ahead="$(git -C "$dir" rev-list --count '@{upstream}..HEAD' 2>/dev/null || echo 0)"
        if [ "$ahead" -gt 0 ]; then
            echo " [${ahead} ahead]"
        else
            echo " [clean]"
        fi
    else
        local modified untracked
        modified="$(echo "$status" | grep -c '^ \?[MADRCU]' || true)"
        untracked="$(echo "$status" | grep -c '^??' || true)"
        local parts=""
        [ "$modified" -gt 0 ] && parts="${modified} modified"
        [ "$untracked" -gt 0 ] && parts="${parts:+${parts}, }${untracked} untracked"
        echo " [${parts}]"
    fi
}

# Gather project directories (one level deep)
if [ ! -d "$PROJECTS_DIR" ]; then
    echo "No ~/Projects directory found."
    exit 1
fi

projects="$(find "$PROJECTS_DIR" -mindepth 1 -maxdepth 1 -type d | sort)"
if [ -z "$projects" ]; then
    echo "No projects found in ~/Projects."
    exit 1
fi

# Build display list with git indicators
display_lines=""
while IFS= read -r dir; do
    name="$(basename "$dir")"
    indicator="$(git_indicator "$dir")"
    display_lines="${display_lines:+${display_lines}
}${name}${indicator}"
done <<< "$projects"

# p <query>: fuzzy match, skip picker if unique
if [ -n "${1:-}" ]; then
    matches="$(echo "$display_lines" | grep -i "$1" || true)"
    match_count="$(echo "$matches" | grep -c . || true)"

    if [ "$match_count" -eq 1 ]; then
        name="${matches%% *}"
        open_project "${PROJECTS_DIR}/${name}"
        exit 0
    elif [ "$match_count" -eq 0 ]; then
        echo "No project matching '$1'."
        exit 1
    fi
    display_lines="$matches"
fi

# Interactive pick
choice="$(echo "$display_lines" | gum filter --header "Projects")"
[ -z "$choice" ] && exit 1
# Strip indicator to get just the project name
name="${choice%% *}"
open_project "${PROJECTS_DIR}/${name}"
